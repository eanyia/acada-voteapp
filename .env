# NaijaVote Application - Environment Configuration Template
# Copy this file to .env and update with your own values

# PostgreSQL Database Configuration
POSTGRES_DB=naijavote

# Spring Boot Application Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/naijavote

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Flyway Configuration
SPRING_FLYWAY_ENABLED=true

# Logging Configuration
LOGGING_LEVEL_COM_NAIJAVOTE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=INFO

# Server Configuration
SERVER_PORT=8080

# Application Profile (optional)
SPRING_PROFILES_ACTIVE=default

